# CDP Platform - DEVELOPMENT
# Copy to .env.development and fill. Do not commit secrets.

CDP_ENV=development

# Shared n8n instance (DEV workflows live beside PROD workflows).
N8N_BASE_URL=https://automacao.tktechnologies.com.br
N8N_WEBHOOK_BASE=${N8N_BASE_URL}/webhook
N8N_API_BASE=${N8N_BASE_URL}/api/v1
N8N_MCP_URL=${N8N_BASE_URL}/mcp-server/http
N8N_API_KEY=
N8N_MCP_AUTH_HEADER=

# n8n DEV workflow IDs (after make import-n8n-dev).
CDP_DEV_ROUTER_WORKFLOW_ID=
CDP_DEV_SCRAPER_WORKFLOW_ID=
CDP_DEV_STOKAPI_WORKFLOW_ID=
CDP_DEV_PROGRESS_WORKFLOW_ID=
CDP_DEV_NOTIFIER_WORKFLOW_ID=

# n8n DEV Telegram credential inside automacao.tktechnologies.com.br.
N8N_DEV_TELEGRAM_CREDENTIAL_ID=
N8N_DEV_TELEGRAM_CREDENTIAL_NAME=Telegram DEV account
TELEGRAM_DEV_ALLOWED_CHAT_IDS=
TELEGRAM_DEV_BOT_TOKEN=

# DEV service APIs.
CDP_DEV_SCRAPER_API_BASE=https://cdp-scrapers-api-dev.happyforest-06c871e6.eastus2.azurecontainerapps.io
CDP_DEV_MUVSTOK_API_BASE=
CDP_DEV_API_KEY=
CDP_DEV_MUVSTOK_API_KEY=
CDP_DEV_CALLBACK_WEBHOOK_SECRET=
CDP_DEV_MUVSTOK_CALLBACK_WEBHOOK_SECRET=

# DEV callback paths on the shared n8n domain.
CDP_DEV_WEBHOOK_URL=https://automacao.tktechnologies.com.br/
CDP_DEV_N8N_WEBHOOK_PATH=webhook/dev-scraper-result
CDP_DEV_MUVSTOK_WEBHOOK_PATH=webhook/dev-muvstok-result
CDP_DEV_NOTIFIER_WEBHOOK_PATH=webhook/dev-cdp-notifier

# DEV Google Sheets (copy production spreadsheet or use clearly separate DEV tabs).
CDP_DEV_SKUS_SHEET_ID=
CDP_DEV_RESULTADOS_SHEET_ID=
CDP_DEV_RESULTADOS_SHEETS_URL=
CDP_DEV_NOTIFICATION_EMAIL_TO=

# Optional DEV tuning.
CDP_DEV_SCRAPER_BATCH_SIZE=
CDP_DEV_SCRAPER_SITES=
CDP_DEV_PROGRESS_INTERVAL_MIN=10
CDP_DEV_PROGRESS_MIN_SKUS=15
CDP_DEV_PROGRESS_MIN_STEP_PCT=10
CDP_DEV_PROGRESS_MAX_MESSAGES=6

# Azure DEV resources.
RESOURCE_GROUP=automation
ACR_NAME=cdpscraperprodacr
DEV_KEY_VAULT=cdp-scrapers-kv-dev
