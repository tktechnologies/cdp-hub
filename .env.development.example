# CDP Platform — DEVELOPMENT (Azure dev stack or local against dev APIs)
# Copy to .env.development and fill. Do not commit secrets.

CDP_ENV=development

# --- n8n (dev instance after deploy-azure-dev) ---
N8N_BASE_URL=https://cdp-n8n-dev.example.azurecontainerapps.io
N8N_WEBHOOK_BASE=${N8N_BASE_URL}/webhook
N8N_API_KEY=

# --- Scraper dev API ---
CDP_SCRAPER_API_BASE=https://cdp-scrapers-api-dev.example.azurecontainerapps.io
CDP_SCRAPER_API_KEY=

# --- StokAPI dev API ---
CDP_STOKAPI_API_BASE=https://cdp-muv-api-dev.example.azurecontainerapps.io
CDP_STOKAPI_API_KEY=

# --- Progress workflow on dev n8n (after import) ---
CDP_PROGRESS_WORKFLOW_ID=

# --- Azure dev Key Vault ---
# AZURE_KEY_VAULT_URL=https://cdp-scrapers-kv-dev.vault.azure.net
# AZURE_REGISTRY=cdpscraperprodacr.azurecr.io
