# CDP Scraper — Production Environment (Azure)
# DO NOT commit with real values. Use Azure Key Vault / GitHub Secrets.

DATABASE_URL=postgresql+asyncpg://cdp:${POSTGRES_PASSWORD}@cdp-pg.postgres.database.azure.com/cdp_scraper?ssl=require
DATABASE_URL_SYNC=postgresql://cdp:${POSTGRES_PASSWORD}@cdp-pg.postgres.database.azure.com/cdp_scraper?sslmode=require
REDIS_URL=rediss://:${REDIS_KEY}@cdp-redis.redis.cache.windows.net:6380/0
SCRAPE_CACHE_REDIS_URL=rediss://:${REDIS_KEY}@cdp-scrapers-redis-prod.redis.cache.windows.net:6380/1
SCRAPE_CACHE_ENABLED=true
SCRAPE_CACHE_TTL_SECONDS=86400
SCRAPE_CACHE_TTL_NOT_FOUND_SECONDS=21600
SCRAPE_CACHE_TTL_BLOCKED_SECONDS=1800
SCRAPE_CACHE_PG_FALLBACK=true
SCRAPE_SITES_SEQUENTIAL=true
JOB_EXECUTION_BACKEND=celery
CELERY_BROKER_URL=rediss://:${REDIS_KEY}@cdp-redis.redis.cache.windows.net:6380/0
CELERY_RESULT_BACKEND=rediss://:${REDIS_KEY}@cdp-redis.redis.cache.windows.net:6380/0
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_TIME_LIMIT_SECONDS=3600

API_HOST=0.0.0.0
API_PORT=8000
API_KEY=${API_KEY}
CALLBACK_WEBHOOK_SECRET=${CALLBACK_WEBHOOK_SECRET}

PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO_MS=0
BROWSER_LOCALE=pt-BR
BROWSER_TIMEZONE_ID=America/Sao_Paulo
BROWSER_ACCEPT_LANGUAGE=pt-BR,pt;q=0.9,en-US;q=0.8,en;q=0.7
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080
BROWSER_USER_AGENTS=[]
BROWSER_EXTRA_HTTP_HEADERS_ENABLED=true
BROWSER_STEALTH_ENABLED=true
MOCK_SCRAPERS=false

# MeliBox (scraper; also optional fallback for Muvstok if CREDENTIAL_MUVSTOK is unset in process)
CREDENTIAL_MELIBOX_USER={MELIBOX_USER}
CREDENTIAL_MELIBOX_PASS={MELIBOX_PASS}
CREDENTIAL_MELIBOX_URL=https://app.melibox.com.br/advProductPosition

CREDENTIAL_GM_USER=${GM_USER}
CREDENTIAL_GM_PASS=${GM_PASS}
CREDENTIAL_GM_URL=https://www.pecachevrolet.com.br

CREDENTIAL_ML_USER=${ML_USER}
CREDENTIAL_ML_PASS=${ML_PASS}
CREDENTIAL_ML_URL=https://lista.mercadolivre.com.br

CREDENTIAL_VW_USER=${VW_USER}
CREDENTIAL_VW_PASS=${VW_PASS}
CREDENTIAL_VW_URL=https://pecas.vw.com.br

CREDENTIAL_EU_USER=${EU_USER}
CREDENTIAL_EU_PASS=${EU_PASS}
CREDENTIAL_EU_URL=https://export.fastparts.is

CREDENTIAL_GOPARTS_USER=${GOPARTS_USER}
CREDENTIAL_GOPARTS_PASS=${GOPARTS_PASS}
CREDENTIAL_GOPARTS_URL=https://goparts.com.br

CREDENTIAL_PROCURAPECAS_USER=${PROCURAPECAS_USER}
CREDENTIAL_PROCURAPECAS_PASS=${PROCURAPECAS_PASS}
CREDENTIAL_PROCURAPECAS_URL=https://www.procurapecas.com.br

CREDENTIAL_PECADIRETA_USER=${PECADIRETA_USER}
CREDENTIAL_PECADIRETA_PASS=${PECADIRETA_PASS}
CREDENTIAL_PECADIRETA_URL=https://www.pecadireta.com.br

CREDENTIAL_EBAY_USER=${EBAY_USER}
CREDENTIAL_EBAY_PASS=${EBAY_PASS}
CREDENTIAL_EBAY_URL=https://www.ebay.com

LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_METRICS=true

MELIBOX_SKU_DELAY_MIN=3.0
MELIBOX_SKU_DELAY_MAX=8.0
MELIBOX_ROTATE_CONTEXT_PER_SKU=false
SCRAPE_DELAY_MIN=4.0
SCRAPE_DELAY_MAX=10.0
SCRAPER_ACTION_DELAY_MIN_MS=600
SCRAPER_ACTION_DELAY_MAX_MS=1800
ANTI_BOT_RETRY_ATTEMPTS=1
ANTI_BOT_BACKOFF_MIN_SECONDS=5.0
ANTI_BOT_BACKOFF_MAX_SECONDS=15.0
ANTI_BOT_BLOCK_STATUS_CODES=[403,429]
MAX_CONCURRENT_SCRAPERS=1

# Proxy: set Key Vault secret proxy-urls to a JSON array, e.g. ["http://user:pass@host:12323"].
# If PROXY_ROTATION_ENABLED=true and PROXY_FAIL_CLOSED=true, empty PROXY_URLS prevents worker start.
PROXY_ROTATION_ENABLED=true
PROXY_URLS=${PROXY_URLS}
PROXY_BYPASS=localhost,127.0.0.1
PROXY_FAIL_CLOSED=true
PROXY_AFFINITY_ENABLED=true
PROXY_STATE_PER_IDENTITY=true
ANTI_BOT_CIRCUIT_BREAKER_ENABLED=true
ANTI_BOT_CIRCUIT_BREAKER_THRESHOLD=3
ANTI_BOT_CIRCUIT_BREAKER_COOLDOWN_SECONDS=1800
