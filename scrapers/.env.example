# ═══════════════════════════════════════════════════════
# CDP Scraper — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy to .env and fill in real values: cp .env.example .env

# --- Database ---
DATABASE_URL=postgresql+asyncpg://cdp:cdp_pass@localhost:5432/cdp_scraper
DATABASE_URL_SYNC=postgresql://cdp:cdp_pass@localhost:5432/cdp_scraper
POSTGRES_PASSWORD=cdp_pass

# --- Redis ---
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Job Execution ---
# local: API executes jobs in-process for development/tests.
# celery: API enqueues jobs to Redis and a Celery worker executes them.
JOB_EXECUTION_BACKEND=local
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_TIME_LIMIT_SECONDS=3600

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
API_KEY=changeme-generate-a-real-key

# --- Mock Mode (for testing) ---
MOCK_SCRAPERS=false

# --- Playwright ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_SLOW_MO_MS=0
BROWSER_STATE_DIR=./browser_states
SCREENSHOT_ON_ERROR=true
SCREENSHOT_DIR=./screenshots
BROWSER_LOCALE=pt-BR
BROWSER_TIMEZONE_ID=America/Sao_Paulo
BROWSER_ACCEPT_LANGUAGE=pt-BR,pt;q=0.9,en-US;q=0.8,en;q=0.7
BROWSER_VIEWPORT_WIDTH=1920
BROWSER_VIEWPORT_HEIGHT=1080
# JSON list. Leave empty to derive a Chromium-compatible UA from Playwright.
BROWSER_USER_AGENTS=[]
BROWSER_EXTRA_HTTP_HEADERS_ENABLED=true
BROWSER_STEALTH_ENABLED=true

# --- Site Credentials ---
# MeliBox (scraper; also optional fallback for Muvstok if CREDENTIAL_MUVSTOK is unset in process)
CREDENTIAL_MELIBOX_USER=
CREDENTIAL_MELIBOX_PASS=
CREDENTIAL_MELIBOX_URL=https://app.melibox.com.br/advProductPosition

CREDENTIAL_GM_USER=
CREDENTIAL_GM_PASS=
CREDENTIAL_GM_URL=https://www.pecachevrolet.com.br

CREDENTIAL_ML_USER=
CREDENTIAL_ML_PASS=
CREDENTIAL_ML_URL=https://lista.mercadolivre.com.br

CREDENTIAL_VW_USER=
CREDENTIAL_VW_PASS=
CREDENTIAL_VW_URL=https://pecas.vw.com.br

CREDENTIAL_EU_USER=
CREDENTIAL_EU_PASS=
CREDENTIAL_EU_URL=https://export.fastparts.is

CREDENTIAL_GOPARTS_USER=
CREDENTIAL_GOPARTS_PASS=
CREDENTIAL_GOPARTS_URL=https://goparts.com.br

CREDENTIAL_PROCURAPECAS_USER=
CREDENTIAL_PROCURAPECAS_PASS=
CREDENTIAL_PROCURAPECAS_URL=https://www.procurapecas.com.br

CREDENTIAL_PECADIRETA_USER=
CREDENTIAL_PECADIRETA_PASS=
CREDENTIAL_PECADIRETA_URL=https://www.pecadireta.com.br

CREDENTIAL_EBAY_USER=
CREDENTIAL_EBAY_PASS=
CREDENTIAL_EBAY_URL=https://www.ebay.com

CREDENTIAL_MELIBOX_USER=
CREDENTIAL_MELIBOX_PASS=
CREDENTIAL_MELIBOX_URL=https://app.melibox.com.br

# --- Vault (optional, for production) ---
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=
# VAULT_MOUNT=secret
# VAULT_PATH=cdp/scrapers

# --- CDP Integration ---
CDP_API_URL=http://localhost:3000/api/v1
CDP_API_KEY=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- External Callback ---
CALLBACK_WEBHOOK_SECRET=changeme

# --- Monitoring ---
ENABLE_METRICS=true
METRICS_PORT=9090

# --- Melibox Behavior ---
SCRAPE_DELAY_MIN=4.0
SCRAPE_DELAY_MAX=10.0
SESSION_RECHECK_SECONDS=900
SCRAPER_ACTION_DELAY_MIN_MS=600
SCRAPER_ACTION_DELAY_MAX_MS=1800
ANTI_BOT_RETRY_ATTEMPTS=1
ANTI_BOT_BACKOFF_MIN_SECONDS=5.0
ANTI_BOT_BACKOFF_MAX_SECONDS=15.0
ANTI_BOT_BLOCK_STATUS_CODES=[403,429]
MELIBOX_SKU_DELAY_MIN=3.0
MELIBOX_SKU_DELAY_MAX=8.0
MELIBOX_ROTATE_CONTEXT_PER_SKU=false
SCRAPE_SITES_SEQUENTIAL=true
MAX_CONCURRENT_SCRAPERS=1

# --- Scrape result cache (Redis DB 1; Celery uses DB 0) ---
SCRAPE_CACHE_ENABLED=true
# Use DB 1 for cache; match REDIS_HOST_PORT when not 6379 (e.g. redis://localhost:6381/1)
SCRAPE_CACHE_REDIS_URL=redis://localhost:6379/1
SCRAPE_CACHE_TTL_SECONDS=86400
SCRAPE_CACHE_TTL_NOT_FOUND_SECONDS=21600
SCRAPE_CACHE_TTL_BLOCKED_SECONDS=1800
SCRAPE_CACHE_PG_FALLBACK=true
SCRAPE_CACHE_BYPASS_STATUSES=["error","timeout"]

# --- Proxy Rotation ---
# JSON list because pydantic-settings parses list env vars from JSON.
PROXY_ROTATION_ENABLED=false
PROXY_URLS=[]
PROXY_BYPASS=localhost,127.0.0.1
PROXY_FAIL_CLOSED=false
PROXY_AFFINITY_ENABLED=false
# Strict alternation applies per SKU (all sites in one SKU share the same IP).
PROXY_STRICT_ALTERNATION=true
PROXY_ROTATE_CONTEXT_PER_SEARCH=true
PROXY_STATE_PER_IDENTITY=true
ANTI_BOT_CIRCUIT_BREAKER_ENABLED=true
ANTI_BOT_CIRCUIT_BREAKER_THRESHOLD=3
ANTI_BOT_CIRCUIT_BREAKER_COOLDOWN_SECONDS=1800
