# Copy to .env: cp .env.example .env
# Production values live in Azure Key Vault `cdp-scrapers-kv-prod` (RG automation).
# Local .env can be generated from KV with the same secret names (see README or team runbook).

APP_NAME="Muvstok API"
APP_VERSION="0.1.0"
ENVIRONMENT="azure-dev"
ENABLE_DOCS=true

# Key Vault: api-key  ->  API_KEYS (comma-separated; single key in prod)
API_KEYS=""

# Key Vault: database-url  (use postgresql+psycopg locally, not asyncpg)
DATABASE_URL="postgresql+psycopg://USER:PASSWORD@HOST:5432/cdp_scraper?sslmode=require"
# Key Vault: database-url-sync
DATABASE_URL_SYNC="postgresql://USER:PASSWORD@HOST:5432/cdp_scraper?sslmode=require"

# Key Vault: redis-url
REDIS_URL="rediss://:PASSWORD@HOST:6380/0"
REDIS_JOB_STREAM="muvstok:jobs"
REDIS_JOB_CONSUMER_GROUP="muvstok-workers"
REDIS_DEAD_LETTER_STREAM="muvstok:jobs:dead-letter"
REDIS_CONSUMER_NAME="worker-1"
REDIS_PENDING_IDLE_MS=300000

MAX_SKUS_PER_JOB=10000
JOB_ITEM_BATCH_SIZE=250

# Per-SKU result cache (avoid re-requesting Muvstok for duplicate/repeat SKUs within TTL).
# In-job duplicates always reuse the first result; this Redis layer covers cross-job repeats.
MUVSTOK_CACHE_ENABLED=true
# Defaults to REDIS_URL when empty; keys use the "muvstok:sku:" prefix (no stream collision).
MUVSTOK_CACHE_REDIS_URL=""
MUVSTOK_CACHE_TTL_SECONDS=86400
MUVSTOK_CACHE_TTL_NOT_FOUND_SECONDS=21600

MUVSTOK_BASE_URL="https://data-bi.muvstok.com.br/api/Demand/"
MUVSTOK_LOGIN_PATH="https://api.integracao.muvstok.com.br/api/Auth/Login"
MUVSTOK_USER=""
MUVSTOK_PASSWORD=""
MUVSTOK_TIMEOUT_SECONDS=30
MUVSTOK_TOKEN_TTL_HOURS=24
MUVSTOK_DEALERSHIP_DIRECTORY_ENABLED=true
MUVSTOK_DEALERSHIP_DIRECTORY_URL="https://docs.google.com/spreadsheets/d/1p76idxvF0z8nl20L1jvNw8CABjbgsf-R/export?format=csv&gid=1843593319"
MUVSTOK_DEALERSHIP_DIRECTORY_URL_FALLBACK_ENABLED=true
MUVSTOK_DEALERSHIP_DIRECTORY_TTL_SECONDS=86400

AZURE_KEY_VAULT_URL="https://cdp-scrapers-kv-prod.vault.azure.net/"
KEY_VAULT_TOKEN_SECRET_NAME="muvstok-api-token"
KEY_VAULT_MUVSTOK_USER_SECRET_NAME="muvstok-user"
KEY_VAULT_MUVSTOK_PASSWORD_SECRET_NAME="muvstok-password"

CALLBACK_WEBHOOK_SECRET=""
CALLBACK_TIMEOUT_SECONDS=30
CALLBACK_MAX_ATTEMPTS=5

# --- n8n / local automation (optional; mirrors cdp-n8n-prod) ---
# Key Vault: api-key -> CDP_MUVSTOK_API_KEY, CDP_API_KEY
# Key Vault: callback-webhook-secret -> CALLBACK_WEBHOOK_SECRET, CDP_MUVSTOK_CALLBACK_WEBHOOK_SECRET
CDP_MUVSTOK_API_BASE="https://cdp-muv-api.bravecoast-b14d791e.eastus2.azurecontainerapps.io"
CDP_MUVSTOK_API_KEY=""
CALLBACK_WEBHOOK_SECRET=""
WEBHOOK_URL="https://automacao.tktechnologies.com.br/"
CDP_MUVSTOK_WEBHOOK_PATH="webhook/muvstok-result"
N8N_BASE_URL="https://automacao.tktechnologies.com.br"
N8N_API_KEY=""
