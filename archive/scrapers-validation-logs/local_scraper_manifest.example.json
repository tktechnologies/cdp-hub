{
  "version": 1,
  "description": "Copy to docs/validation/local_scraper_manifest.local.json and replace every placeholder with manually verified real values before running local scraper validation.",
  "require_real_scrapers": true,
  "cases": [
    {
      "id": "gm-known",
      "site": "gm",
      "sku": "REPLACE_WITH_REAL_GM_SKU",
      "brand": "GM",
      "expect_result": true,
      "expected_currency": "BRL",
      "expected_condition": "new",
      "expected_price_min": 1.0,
      "expected_price_max": 999999.0,
      "evidence_url": "https://www.pecachevrolet.com.br"
    },
