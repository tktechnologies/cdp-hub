{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScraperJobRequest",
  "description": "POST /api/v1/jobs body. Source: scrapers/src/models/schemas.py ScrapeJobRequest",
  "type": "object",
  "required": ["items"],
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "maxItems": 500,
      "items": {
        "type": "object",
        "required": ["sku"],
        "properties": {
          "sku": { "type": "string" },
          "brand": { "type": "string", "default": "" },
          "description": { "type": "string", "default": "" }
        }
      }
    },
    "sites": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Site IDs: gm, ml, vw, eu, pecadireta, melibox, ..."
    },
    "callback_url": { "type": ["string", "null"], "format": "uri" },
    "priority": { "type": "integer", "minimum": 1, "maximum": 10, "default": 5 },
    "force_refresh": { "type": "boolean", "default": false },
    "batch_group_id": { "type": ["string", "null"] },
    "chat_id": { "type": ["string", "null"] },
    "command_route": { "type": ["string", "null"] }
  }
}
